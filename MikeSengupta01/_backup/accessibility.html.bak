<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Erklärung zur Barrierefreiheit / Accessibility Statement - Mike Sengupta">
    <title>Erklärung zur Barrierefreiheit | Mike Sengupta</title>
    <script>
        try {
            if (localStorage.getItem("a11y_large") === "true") {
                document.documentElement.classList.add("a11y-large-text");
            }
        } catch (e) {}
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <!-- Skip to Content -->
    <a href="#main-content" class="skip-link" data-i18n="a11y.skip">Zum Hauptinhalt springen</a>

    <!-- Header -->
    <header class="header" role="banner">
        <div class="logo"><a href="index.html" style="color: inherit; text-decoration: none;">MIKE<span>SENGUPTA</span></a></div>
        <nav role="navigation" aria-label="Main Navigation">
            <ul class="nav-links">
                <li><a href="index.html#about" data-i18n="nav.about">Über mich</a></li>
                <li><a href="index.html#services" data-i18n="nav.services">Leistungen</a></li>
                <li><a href="index.html#contact" data-i18n="nav.contact">Kontakt</a></li>
                
                <li class="lang-switch">
                    <span class="lang-lbl de">DE</span>
                    <label class="switch">
                        <input type="checkbox" id="lang-toggle" aria-label="Toggle Language">
                        <span class="slider"></span>
                    </label>
                    <span class="lang-lbl en">EN</span>
                </li>
            </ul>
        </nav>
        <button class="mobile-menu-btn" aria-label="Menu" aria-expanded="false"><i class="fa-solid fa-bars"></i></button>
    </header>

    <!-- Main Content -->
    <main id="main-content" role="main" style="padding-top: 7rem; min-height: 80vh;">
        <section class="fade-in" style="padding: 4rem 10%;">
            <h1 data-i18n="a11y.page_title" style="margin-bottom: 2rem;">Erklärung zur Barrierefreiheit</h1>
            
            <p data-i18n="a11y.intro" style="margin-bottom: 2rem;">Ich, Mike Sengupta, bin bemüht, meine Website im Einklang mit den nationalen Rechtsvorschriften und den Richtlinien für barrierefreie Webinhalte (WCAG 2.1 Level AA) sowie dem Barrierefreiheitsstärkungsgesetz (BFSG) barrierefrei zugänglich zu machen.</p>

            <h2 data-i18n="a11y.h2_status">Stand der Vereinbarkeit mit den Anforderungen</h2>
            <p data-i18n="a11y.status_text" style="margin-bottom: 2rem;">Diese Website ist vollständig mit den Anforderungen der WCAG 2.1 (Level AA) und der EN 301 549 vereinbar.</p>

            <h2 data-i18n="a11y.h2_features">Unsere Bemühungen</h2>
            <ul style="list-style-position: inside; margin-bottom: 2rem; color: var(--text-secondary);">
                <li data-i18n="a11y.li1">Bereitstellung eines Accessibility-Panels (hoher Kontrast, Textskalierung).</li>
                <li data-i18n="a11y.li2">Tastaturfreundliche Navigation durch ARIA-Landmarks.</li>
                <li data-i18n="a11y.li3">Semantisches HTML und Alternativtexte für alle Bilder.</li>
            </ul>

            <h2 data-i18n="a11y.h2_contact">Kontakt bei Hindernissen</h2>
            <p data-i18n="a11y.contact_text" style="margin-bottom: 2rem;">Sollten Ihnen Mängel in Bezug auf die barrierefreie Gestaltung unserer Seite auffallen, kontaktieren Sie uns gerne. Wir bemühen uns um eine schnelle Behebung.</p>
        </section>
    </main>

    <!-- Footer -->
    <footer role="contentinfo">
        <p>&copy; 2026 Mike Sengupta. <span data-i18n="footer.rights">Alle Rechte vorbehalten.</span> | <a href="accessibility.html" style="text-decoration: underline;" data-i18n="a11y.link">Barrierefreiheit</a> | <a href="#" id="imprint-toggle" style="text-decoration: underline;" data-i18n="footer.imprint">Impressum</a></p>
    </footer>

    <!-- Accessibility Panel Elements -->
    <button id="a11y-toggle" class="a11y-toggle-btn" aria-label="Open Accessibility Menu" aria-expanded="false">
        <i class="fa-solid fa-universal-access"></i>
    </button>

    <div id="a11y-panel" class="a11y-panel" aria-hidden="true" role="dialog" aria-labelledby="a11y-panel-title">
        <div class="a11y-header">
            <h3 id="a11y-panel-title" data-i18n="a11y.panel_title">Barrierefreiheit (A11Y)</h3>
            <button id="a11y-close" aria-label="Close Accessibility Menu"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="a11y-options">
            <button class="a11y-option-btn" id="a11y-hc" data-i18n="a11y.high_contrast"><i class="fa-solid fa-circle-half-stroke"></i> Hoher Kontrast</button>
            <button class="a11y-option-btn" id="a11y-txt-up" data-i18n="a11y.text_up"><i class="fa-solid fa-text-height"></i> Text Vergrößern</button>
            <button class="a11y-option-btn" id="a11y-txt-reset" data-i18n="a11y.text_reset"><i class="fa-solid fa-rotate-left"></i> Standard Text</button>
            <button class="a11y-option-btn" id="a11y-dys" data-i18n="a11y.dyslexia"><i class="fa-solid fa-font"></i> Lesefreundliche Schrift</button>
            <button class="a11y-option-btn" id="a11y-anim" data-i18n="a11y.animations"><i class="fa-solid fa-ban"></i> Animationen stoppen</button>
        </div>
    </div>

    <!-- Impressum / Imprint Modal -->
    <div id="imprint-modal" class="modal" aria-hidden="true" role="dialog" aria-labelledby="imprint-title">
        <div class="modal-overlay" tabindex="-1"></div>
        <div class="modal-container">
            <div class="modal-header">
                <h3 id="imprint-title" data-i18n="imprint.title">Impressum</h3>
                <button class="modal-close" id="imprint-close" aria-label="Impressum schließen"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <p class="imprint-name">Mike Sen Gupta</p>
                <p>Hildesheimer Weg 18</p>
                <p>22459 Hamburg</p>
                <div class="imprint-divider"></div>
                <p><strong><span data-i18n="imprint.mobile">Mobil</span>:</strong> <a href="tel:+491796306300">0179 6306300</a></p>
                <p><strong><span data-i18n="imprint.email">E-Mail</span>:</strong> <a href="mailto:mike_sen_gupta@gmx.de">mike_sen_gupta@gmx.de</a></p>
            </div>
        </div>
    </div>

    <!-- Logic -->
    <script src="js/translations.js"></script>
    <script src="js/i18n.js"></script>
    <script src="js/main.js"></script>
    <script src="js/a11y.js"></script>
</body>
</html>
